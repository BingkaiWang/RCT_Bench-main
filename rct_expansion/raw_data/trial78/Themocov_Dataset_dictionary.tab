Heparina_no_fracc,"Use of Unfractionated heparin in-hospital, yes=1, no=0"
Heparina_bajo_peso,"Use of Low molecular weight heparin in-hospital, yes=1, no=0"
Plasma_convaleciente,"Use of Convalescent plasma in-hospital, yes=1, no=0"
Remdesivir,"Use of Remdesivir in-hospital, yes=1, no=0"
Inmunoglobulina_IV,"Use of IV immunoglobulin in-hospital, yes=1, no=0"
Vitamina_C,"Use of Vitamin C in-hospital, yes=1, no=0"
Lopi_Rito,"Use of Lopinavir-Ritonavir in-hospital, yes=1, no=0"
No_Sesiones_Termoterapia,Number of thermotherapy sessions
Duracion_Promedio_Sesion,"Average duration, in minutes, of thermotherapy sessions"
Duracion_Total,"Total duration, in minutes, of thermotherapy during the 5 days of intervention"
Tolerancia_Paciente,"Intervention tolerance, yes=1, no=0"
Eventos_Adversos,"Any adverse event, yes, no"
Codigo_EA_1,Adverse event code number 1
Nombre_EA_1,Name of adverse event number 1
EA_1_Desenlace,"Adverse event number 1 according to outcome, 1=severe (causes death, puts life at risk, prolongs hospitalization or causes disability), 0=Not severe (none of the above)"
EA_1_Gravedad,"Severity of adverse event number 1, 1=mild (grade 1), 2=moderate (grade 2), 3=severe (grade 3, 4 and 5)"
EA_1_Causalidad,"Causality of adverse event number 1, 1=Certain, 2=Probable, 3=Possible, 4=Doubtful, 5=Not evaluable-unclassifiable"
Codigo_EA_2,Adverse event code number 2
Nombre_EA_2,Name of adverse event number 2
EA_2_Desenlace,"Adverse event number 2 according to outcome, 1=severe (causes death, puts life at risk, prolongs hospitalization or causes disability), 0=Not severe (none of the above)"
EA_2_Gravedad,"Severity of adverse event number 2, 1=mild (grade 1), 2=moderate (grade 2), 3=severe (grade 3, 4 and 5)"
EA_2_Causalidad,"Causality of adverse event number 2, 1=Certain, 2=Probable, 3=Possible, 4=Doubtful, 5=Not evaluable-unclassifiable"
Codigo_EA_3,Adverse event code number 3
Nombre_EA_3,Name of adverse event number 3
EA_3_Desenlace,"Adverse event number 3 according to outcome, 1=severe (causes death, puts life at risk, prolongs hospitalization or causes disability), 0=Not severe (none of the above)"
EA_3_Gravedad,"Severity of adverse event number 3, 1=mild (grade 1), 2=moderate (grade 2), 3=severe (grade 3, 4 and 5)"
EA_3_Causalidad,"Causality of adverse event number 3, 1=Certain, 2=Probable, 3=Possible, 4=Doubtful, 5=Not evaluable-unclassifiable"
Codigo_EA_4,Adverse event code number 4
Nombre_EA_4,Name of adverse event number 4
EA_4_Desenlace,"Adverse event number 4 according to outcome, 1=severe (causes death, puts life at risk, prolongs hospitalization or causes disability), 0=Not severe (none of the above)"
EA_4_Gravedad,"Severity of adverse event number 4, 1=mild (grade 1), 2=moderate (grade 2), 3=severe (grade 3, 4 and 5)"
EA_4_Causalidad,"Causality of adverse event number 4, 1=Certain, 2=Probable, 3=Possible, 4=Doubtful, 5=Not evaluable-unclassifiable"
Tiempo_hasta_cualquier_progresion_28_dias,"Time, in days, from randomization to disease progression (composite outcome, severe or critical) censored to 28 days"
Progresion_cualquiera_28_dias,"Progression of disease during the first 28 days (composite outcome, severe or critical), 1=yes, 0=no "
tiempo_hasta_progresion_crítico,"Time, in days, from randomization to disease progression to critical, censored to 28 days"
Progresion_a_critico,"Progression of disease to critical during the first 28 days, 1=yes, 0=no "
dias_hasta_mortalidad,"Time, in days, from randomization to mortality"
tiempo_hasta_mortalidad_15_dias,"Time, in days, from randomization to mortality, censored to 15 days"
mortalidad_15_dias,"Mortality during the first 15 days, 1=yes, 0=no "
tiempo_hasta_mortalidad_28_dias,"Time, in days, from randomization to mortality, censored to 28 days"
mortalidad_28_dias,"Mortality during the first 28 days, 1=yes, 0=no "
dias_hasta_severo_desde_inicio_sintomas,"Time, in days, from onset of symptoms to disease progression to severe COVID-19"
estado_clinico_ordinal_15_dias,"Clinical status in the Ordinal Scale at Day 15, 1=Not hospitalized, without limitations on daily activities; 2=Not hospitalized, with limitations on daily activities; 3=Hospitalized, not requiring supplementary oxygen; 4=Hospitalized, requiring low-flow supplementary oxygen; 5=Hospitalized, requiring supplementary oxygen with high-flow nasal cannula or non-invasive ventilation; 6=Hospitalized, under invasive mechanical ventilation or extracorporeal membrane oxygenation (ECMO); 7=Death"
estado_clinico_ordinal_28_dias,"Clinical status in the Ordinal Scale at Day 28, 1=Not hospitalized, without limitations on daily activities; 2=Not hospitalized, with limitations on daily activities; 3=Hospitalized, not requiring supplementary oxygen; 4=Hospitalized, requiring low-flow supplementary oxygen; 5=Hospitalized, requiring supplementary oxygen with high-flow nasal cannula or non-invasive ventilation; 6=Hospitalized, under invasive mechanical ventilation or extracorporeal membrane oxygenation (ECMO); 7=Death"
tiempo_hasta_VMI_28_días,"Time, in days, from randomization to requirement for invasive mechanical ventilation, censored to 28 days"
tiempo_hasta_UCI_28_dias,"Time, in days, from randomization to intensive care unit admission, censored to 28 days"
dias_hasta_VMI_desde_inicio_sintomas,"Time, in days, from onset of symptoms to requirement of invasive mechanical ventilation"
dias_hasta_UCI_desde_inicio_sintomas,"Time, in days, from onset of symptoms to intensive care unit admission"
dias_estancia_hospital,"Length of hospitalization, in days"
dias_desde_inicio_sint_hasta_ingreso_hosp,"Time, in days, from onset of symptoms to hospital admission"
