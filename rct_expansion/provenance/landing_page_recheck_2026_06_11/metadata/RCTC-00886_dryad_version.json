can Training and Research Centre in Administration for Development","ror_id":"https://ror.org/0167m9538"}],"orcid":null,"order":null},{"firstName":"Ellie","lastName":"Sherrard-Smith","email":"e.sherrard-smith@imperial.ac.uk","affiliation":"Imperial College London","affiliationROR":"https://ror.org/041kmwe10","affiliations":[{"name":"Imperial College London","ror_id":"https://ror.org/041kmwe10"}],"orcid":"0000-0001-8317-7992","order":null},{"firstName":"Geraldine M.","lastName":"Foster","email":"Geraldine.Foster@lstmed.ac.uk","affiliation":"Liverpool School of Tropical Medicine","affiliationROR":"https://ror.org/03svjbs84","affiliations":[{"name":"Liverpool School of Tropical Medicine","ror_id":"https://ror.org/03svjbs84"}],"orcid":null,"order":null},{"firstName":"Thomas S.","lastName":"Churcher","email":"thomas.churcher@imperial.ac.uk","affiliation":"Imperial College London","affiliationROR":"https://ror.org/041kmwe10","affiliations":[{"name":"Imperial College London","ror_id":"https://ror.org/041kmwe10"}],"orcid":"0000-0002-8442-0525","order":null},{"firstName":"Josephine E.A.","lastName":"Parker","email":"Josephine.Parker@lstmed.ac.uk","affiliation":"Liverpool School of Tropical Medicine","affiliationROR":"https://ror.org/03svjbs84","affiliations":[{"name":"Liverpool School of Tropical Medicine","ror_id":"https://ror.org/03svjbs84"}],"orcid":null,"order":null},{"firstName":"Catherine E.","lastName":"Towers","email":"C.E.Towers@warwick.ac.uk","affiliation":"University of Warwick","affiliationROR":"https://ror.org/01a77tt86","affiliations":[{"name":"University of Warwick","ror_id":"https://ror.org/01a77tt86"}],"orcid":null,"order":null},{"firstName":"Sagnon","lastName":"N’Falé","email":"n.fale.cnlp@fasonet.bf","affiliation":"African Training and Research Centre in Administration for Development","affiliationROR":"https://ror.org/0167m9538","affiliations":[{"name":"African Training and Research Centre in Administration for Development","ror_id":"https://ror.org/0167m9538"}],"orcid":null,"order":null},{"firstName":"Wamdaogo M.","lastName":"Guelbeogo","email":"guelbeogo.cnrfp@fasonet.bf","affiliation":"African Training and Research Centre in Administration for Development","affiliationROR":"https://ror.org/0167m9538","affiliations":[{"name":"African Training and Research Centre in Administration for Development","ror_id":"https://ror.org/0167m9538"}],"orcid":null,"order":null},{"firstName":"Hilary","lastName":"Ranson","email":"Hilary.Ranson@lstmed.ac.uk","affiliation":"Liverpool School of Tropical Medicine","affiliationROR":"https://ror.org/03svjbs84","affiliations":[{"name":"Liverpool School of Tropical Medicine","ror_id":"https://ror.org/03svjbs84"}],"orcid":null,"order":null},{"firstName":"David","lastName":"Towers","email":"D.Towers@warwick.ac.uk","affiliation":"University of Warwick","affiliationROR":"https://ror.org/01a77tt86","affiliations":[{"name":"University of Warwick","ror_id":"https://ror.org/01a77tt86"}],"orcid":null,"order":null},{"firstName":"Philip J.","lastName":"McCall","email":"Philip.McCall@lstmed.ac.uk","affiliation":"Liverpool School of Tropical Medicine","affiliationROR":"https://ror.org/03svjbs84","affiliations":[{"name":"Liverpool School of Tropical Medicine","ror_id":"https://ror.org/03svjbs84"}],"orcid":"0000-0002-0007-3985","order":null}],"abstract":"\u003cp style=\"margin-right:-3px;margin-bottom:8px;\"\u003eTransmission of \u003ci\u003ePlasmodium falciparum \u003c/i\u003emalaria parasites occurs when nocturnal \u003ci\u003eAnopheles \u003c/i\u003emosquito vectors feed on human blood. In Africa, where malaria burden is greatest, bednets treated with pyrethroid insecticide were highly effective in preventing mosquito bites and reducing transmission, and essential to achieving unprecedented reductions in malaria until 2015. Since then, progress has stalled and with insecticidal bednets losing efficacy against pyrethroid-resistant \u003ci\u003eAnopheles\u003c/i\u003e vectors, methods that restore performance are urgently needed to eliminate any risk of malaria returning to the levels seen prior to their widespread use throughout sub-Saharan Africa.  Here we show that the primary malaria vector \u003ci\u003eAnopheles gambiae\u003c/i\u003e is targeted and killed by small insecticidal net barriers positioned above a standard bednet, in a spatial region of high mosquito activity but zero contact with sleepers, opening the way for deploying many more insecticides on bednets than currently possible.  Tested against wild pyrethroid-resistant \u003ci\u003eAnopheles gambiae \u003c/i\u003ein Burkina Faso, pyrethroid bednets with organophosphate barriers achieved significantly higher killing rates than bednets alone.  Treated barriers on untreated bednets were equally effective, without significant loss of personal protection. Mathematical modelling of transmission dynamics predicted reductions in clinical malaria incidence with barrier bednets that exceeded those of ‘next-generation’ nets recommended by WHO against resistant vectors. Mathematical models of mosquito-barrier interactions identified alternative barrier designs to increase performance.  Barrier bednets that overcome insecticide resistance are feasible using existing insecticides and production technology, and early implementation of affordable vector control tools is a realistic prospect.\u003c/p\u003e\r\n","funders":[{"organization":"MRC","identifierType":null,"identifier":"","awardNumber":"MC_PC_13069","awardURI":null,"awardDescription":null,"awardTitle":null,"order":null},{"organization":"MRC/DFID","identifierType":null,"identifier":"","awardNumber":"MR/M011941/1","awardURI":null,"awardDescription":null,"awardTitle":null,"order":null},{"organization":"Wellcome Trust","identifierType":"ror","identifier":"https://ror.org/029chgv08","awardNumber":"200222/Z/15/Z","awardURI":null,"awardDescription":null,"awardTitle":null,"order":null}],"keywords":["Malaria","Parasitology"],"usageNotes":"\u003cp\u003e\u003cstrong\u003eBB_Hut_Trial_2017_rotation_plan_Dryad_Sept_2019.xlsx \u003c/strong\u003e\u003c/p\u003e\r\n\r\n\u003cp\u003eHut trial data from Tengrela village, Cascades region, Burkina Faso, 16/07/2017 - 25/08/2017. Data formatted as simplified version of Kiware \u003cem\u003eet al\u003c/em\u003e 2016 ED 2 framework  (https://scfbm.biomedcentral.com/articles/10.1186/s13029-016-0050-1). The second sheet details the randomised hut trial full latin-square rotation plan. Any missing values are detailed in the notes section. \u003c/p\u003e\r\n\r\n\u003ctable style=\"border-collapse:collapse;width:81pt;border:none;\" width=\"108\"\u003e\r\n\t\u003ccolgroup\u003e\r\n\t\t\u003ccol style=\"width:81pt;\" width=\"108\"\u003e\r\n\t\u003c/colgroup\u003e\r\n\t\u003ctbody\u003e\r\n\t\t\u003ctr height=\"20\" style=\"height:15.0pt;\"\u003e\r\n\t\t\t\u003ctd align=\"right\" class=\"xl63\" height=\"20\" style=\"border:none;height:15.0pt;width:81pt;padding-top:1px;padding-right:1px;padding-left:1px;vertical-align:bottom;white-space:nowrap;\" width=\"108\"\u003e \u003c/td\u003e\r\n\t\t\u003c/tr\u003e\r\n\t\u003c/tbody\u003e\r\n\u003c/table\u003e\r\n\r\n\u003cp\u003e \u003c/p\u003e\r\n","relatedWorks":[{"relationship":"primary_article","identifierType":"DOI","identifier":"https://doi.org/10.1038/s41564-019-0607-2"}],"versionNumber":3,"versionStatus":"submitted","curationStatus":"Published","versionChanges":"metadata_changed","publicationDate":"2020-01-06","lastModificationDate":"2020-01-06","visibility":"public","sharingLink":"http://datadryad.org/dataset/doi:10.5061/dryad.hqbzkh1b7","changedFields":["authors",[{"index":0,"firstName":"Gregory P.D."},{"index":4,"firstName":"K. Hyacinthe"},{"index":6,"firstName":"Geraldine M."},{"index":7,"firstName":"Thomas S."},{"index":8,"firstName":"Josephine E.A."},{"index":9,"firstName":"Catherine E."},{"index":11,"firstName":"Wamdaogo M."},{"index":14,"firstName":"Philip J."}],"subjects",[{"index":0,"subject":"Malaria"},{"index":1,"subject":"Parasitology"}],"