e":"authorIdentifierScheme","multiple":false,"typeClass":"controlledVocabulary","value":"ORCID"},"authorIdentifier":{"typeName":"authorIdentifier","multiple":false,"typeClass":"primitive","value":"https://orcid.org/0009-0002-2330-4624","expandedvalue":{"personName":"Li, Yichu","@id":"https://orcid.org/0009-0002-2330-4624","scheme":"ORCID","@type":"https://schema.org/Person"}}},{"authorName":{"typeName":"authorName","multiple":false,"typeClass":"primitive","value":"Jianmin Ai"},"authorAffiliation":{"typeName":"authorAffiliation","multiple":false,"typeClass":"primitive","value":"https://ror.org/0170z8493","expandedvalue":{"scheme":"http://www.grid.ac/ontology/","termName":"Shaanxi Normal University","@type":"https://schema.org/Organization"}}},{"authorName":{"typeName":"authorName","multiple":false,"typeClass":"primitive","value":"Yaojiang Shi"},"authorAffiliation":{"typeName":"authorAffiliation","multiple":false,"typeClass":"primitive","value":"https://ror.org/0170z8493","expandedvalue":{"scheme":"http://www.grid.ac/ontology/","termName":"Shaanxi Normal University","@type":"https://schema.org/Organization"}}}]},{"typeName":"datasetContact","multiple":true,"typeClass":"compound","value":[{"datasetContactName":{"typeName":"datasetContactName","multiple":false,"typeClass":"primitive","value":"Jingchun Nie"},"datasetContactAffiliation":{"typeName":"datasetContactAffiliation","multiple":false,"typeClass":"primitive","value":"Shaanxi normal university"},"datasetContactEmail":{"typeName":"datasetContactEmail","multiple":false,"typeClass":"primitive","value":"niejingchun@snnu.edu.cn"}}]},{"typeName":"dsDescription","multiple":true,"typeClass":"compound","value":[{"dsDescriptionValue":{"typeName":"dsDescriptionValue","multiple":false,"typeClass":"primitive","value":"This dataset contains the replication code and anonymized data for the paper 'Spillover Effect of One-off Subsidies on Long-Run Health Products Adoption: Experimental Evidence from Free Eyeglasses in Rural China'. Below is the abstract of the paper:One-off subsidies are widely used to promote health product adoption, yet existing evidence largely overlooks spillover effects on non-recipients—particularly in settings with strong social interactions between recipients and their non-recipients peers, such as among adolescents. Using a randomized controlled trial conducted in rural junior high schools in China, we study the effects of providing free, high-quality eyeglasses to myopic students on subsequent eyeglass adoption among non-recipient classmates who later develop vision impairment. We find that free provision increases adoption among non-experimental students by 2.4 percentage points. Results are robust across various examinations. Mechanism tests reject price anchoring and social learning as primary channels. Instead, the evidence points to a social-norm mechanism: increased peer adoption reduces stigma associated with wearing eyeglasses. Spillover effects are larger in more stigmatized environments, and higher peer ownership significantly reduces teasing and increases adoption. These findings suggest that evaluations focusing solely on direct effects may substantially understate the welfare gains from subsidy-based health interventions."},"dsDescriptionDate":{"typeName":"dsDescriptionDate","multiple":false,"typeClass":"primitive","value":"2026-4-27"}}]},{"typeName":"subject","multiple":true,"typeClass":"controlledVocabulary","value":["Social Sciences"]},{"typeName":"keyword","multiple":true,"typeClass":"compound","value":[{"keywordValue":{"typeName":"keywordValue","multiple":false,"typeClass":"primitive","value":"one-off subsidies"}},{"keywordValue":{"typeName":"keywordValue","multiple":false,"typeClass":"primitive","value":"long-run adoption"}},{"keywordValue":{"typeName":"keywordValue","multiple":false,"typeClass":"primitive","value":"spillover effect"}},{"keywordValue":{"typeName":"keywordValue","multiple":false,"typeClass":"primitive","value":"randomized controlled trial"}},{"keywordValue":{"typeName":"keywordValue","multiple":false,"typeClass":"primitive","value":"social learning"}},{"keywordValue":{"typeName":"keywordValue","multiple":false,"typeClass":"primitive","value":"price anchoring effect"}}]},{"typeName":"depositor","multiple":false,"typeClass":"primitive","value":"Yuan, Yi"},{"typeName":"dateOfDeposit","multiple":false,"typeClass":"primitive","value":"2026-04-27"}]}},"files":[{"description":"Stata code to replicate all empirical results (Table 2 to Table 6) and the coefficient plot presented in the manuscript.","label":"Long_term_adoption_code.do","restricted":false,"version":1,"datasetVersionId":728535,"dataFile":{"id":13712984,"persistentId":"","filename":"Long_term_adoption_code.do","contentType":"text/x-stata-syntax","friendlyType":"Stata Syntax","filesize":12622,"description":"Stata code to replicate all empirical results (Table 2 to Table 6) and the coefficient plot presented in the manuscript.","storageIdentifier":"s3://dvn-cloud-iqss:19dce80a8dd-2f4fcb727093","rootDataFileId":-1,"md5":"245d15c147b875883cf592e832002c0a","checksum":{"type":"MD5","value":"245d15c147b875883cf592e832002c0a"},"tabularData":false,"creationDate":"2026-04-27","publicationDate":"2026-04-27","lastUpdateTime":"2026-04-27T15:00:23Z","fileAccessRequest":true}},{"description":"Anonymized dataset containing all the necessary variables used for the main regressions, heterogeneity analysis, and mechanism analysis.","label":"Long_term_adoption_Dataverse.tab","restricted":false,"version":3,"datasetVersionId":728535,"dataFile":{"id":13712983,"persistentId":"","filename":"Long_term_adoption_Dataverse.tab","contentType":"text/tab-separated-values","friendlyType":"Tab-Delimited","filesize":320242,"description":"Anonymized dataset containing all the necessary variables used for the main regressions, heterogeneity analysis, and mechanism analysis.","storageIdentifier":"s3://dvn-cloud-iqss:19dce804542-687730846cc6","originalFileFormat":"application/