pe": "application/vnd.ms-excel"}], "folder_structure": {}, "authors": [{"id": 12812284, "full_name": "BRUNO RONCAGLIO", "first_name": "BRUNO", "last_name": "RONCAGLIO", "is_active": false, "url_name": "_", "orcid_id": ""}, {"id": 12812287, "full_name": "RAPHAEL FERNANDES CALHAU", "first_name": "RAPHAEL FERNANDES", "last_name": "CALHAU", "is_active": false, "url_name": "_", "orcid_id": ""}, {"id": 12812290, "full_name": "CHARBEL JACOB J\u00daNIOR", "first_name": "CHARBEL", "last_name": "JACOB J\u00daNIOR", "is_active": false, "url_name": "_", "orcid_id": ""}, {"id": 12812293, "full_name": "IGOR MACHADO CARDOSO", "first_name": "IGOR MACHADO", "last_name": "CARDOSO", "is_active": false, "url_name": "_", "orcid_id": ""}, {"id": 12812296, "full_name": "JOS\u00c9 LUCAS BATISTA J\u00daNIOR", "first_name": "JOS\u00c9 LUCAS", "last_name": "BATISTA J\u00daNIOR", "is_active": false, "url_name": "_", "orcid_id": ""}, {"id": 12812299, "full_name": "JOELMAR CESAR ALMEIDA", "first_name": "JOELMAR CESAR", "last_name": "ALMEIDA", "is_active": false, "url_name": "_", "orcid_id": ""}], "custom_fields": [{"name": "Read full text", "value": ["http://www.scielo.br/scielo.php?script=sci_arttext&pid=S1808-18512017000300188&lng=en&tlng=en"], "settings": {"placeholder": "Read full text", "is_multiple": false}, "field_type": "url", "order": null, "is_mandatory": false}], "figshare_url": "https://scielo.figshare.com/articles/dataset/ANALGESIC_EFFICACY_OF_EPIDURAL_MORPHINE_AND_CLONIDINEIN_PATIENTS_UNDERGOING_DECOMPRESSION_OF_THE_LUMBAR_CANAL_A_PROSPECTIVE_RANDOMIZED_TRIAL/20014042", "download_disabled": false, "description": "<div><p>ABSTRACT  Objective: To evaluate the postoperative analgesic efficacy in patients undergoing lumbar canal decompression using epidural morphine and clonidine at the Hospital Santa Casa de Vit\u00f3ria - ES, Brazil.  Methods: Prospective, randomized study of 60 patients with stenosis of the lumbar canal up to two levels with surgical indication, in which decompression of the canal was performed in association with lumbar arthrodesis. In group 1 we performed conventional postoperative analgesia and in group 2, in addition to conventional analgesia, we associated epidural morphine and clonidine. We used VAS as a means of analyzing pain intensity at 1, 12, and 36 hours after surgery. The statistical analysis was performed using Microsoft Office/Excel and the software GraphPad Prism (San Diego, CA, USA).  Results: The mean age of patients was 47 years, and 52% were female. The mean VAS in the first hour, 12th, and 36th hours after surgery in the control group was 5.44, 2.13, and 0.55 respectively. In the morphine-clonidine group it was 6.96; 2.21 and 0.60. Comparing one group with another in its absolute values through the Mann-Whitney test, as well as comparing the pain variations between the 1st and 12th hour (1h X 12h) and between the 12th hour and 36th hour (12h x 36h ) through Student\u2019s t test it became clear that there was no statistical difference between groups (p > 0.05).  Conclusions: The addition of epidural morphine and clonidine to conventional analgesia is not beneficial to reduce postoperative pain in patients undergoing lumbar canal decompression.</p></div>", "funding": null, "funding_list": [], "version": 1, "status": "public", "size": 39424, "created_date": "2022-06-07T10:03:28Z", "modified_date": "2023-06-06T22:24:33Z", "is_public": true, "is_confidential": false, "is_metadata_record": false, "confidential_reason": "", "metadata_reason": "", "license": {"value": 1, "name": "CC BY 4.0", "url": "https://creativecommons.org/licenses/by/4.0/"}, "tags": ["Lumbar vertebrae; Analgesia, epidural", "Morphine", "Clonidine", "Visual analog scale", "Postoperative period"], "keywords": ["Lumbar vertebrae; Analgesia, epidural", "Morphine", "Clonidine", "Visual analog scale", "Postoperative period"], "categories": [{"id": 314, "title": "Orthopaedics", "parent_id": 142, "path": "", "source_id": "", "taxonomy_id": 10}, {"id": 321, "title": "Rehabilitation and Therapy (excl. Physiotherapy)", "parent_id": 142, "path": "", "source_id": "", "taxonomy_id": 10}], "references": ["https://doi.org/10.1590/s1808-185120171603159402"], "has_linked_file": false, "citation": "RONCAGLIO, BRUNO; CALHAU, RAPHAEL FERNANDES; JACOB J\u00daNIOR, CHARBEL; CARDOSO, IGOR MACHADO; BATISTA J\u00daNIOR, JOS\u00c9 LUCAS; ALMEIDA, JOELMAR CESAR (2017). ANALGESIC EFFICACY OF EPIDURAL MORPHINE AND CLONIDINEIN PATIENTS UNDERGOING DECOMPRESSION OF THE LUMBAR CANAL: A PROSPECTIVE RANDOMIZED TRIAL. SciELO journals. Dataset. https://doi.org/10.6084/m9.figshare.20014042.v1", "related_materials": [{"id": 53216744, "identifier": "10.1590/s1808-185120171603159402", "title": "ANALGESIC EFFICACY OF EPIDURAL MORPHINE AND CLONIDINEIN PATIENTS UNDERGOING DECOMPRESSION OF THE LUMBAR CANAL: A PROSPECTIVE RANDOMIZED TRIAL", "relation": "IsSupplementTo", "identifier_type": "DOI", "is_linkout": true, "link": "https://doi.org/10.1590/s1808-185120171603159402"}], "is_embargoed": false, "embargo_date": null, "embargo_type": null, "embargo_title": "", "embargo_reason": "", "embargo_options": [], "id": 20014042, "title": "ANALGESIC EFFICACY OF EPIDURAL MORPHINE AND CLONIDINEIN PATIENTS UNDERGOING DECOMPRESSION OF THE LUMBAR CANAL: A PROSPECTIVE RANDOMIZED TRIAL", "doi": "10.6084/m9.figshare.20014042.v1", "handle": "", "url": "https://api.figshare.com/v2/articles/20014042", "published_date": "2022-06-07T10:03:28Z", "thumb": "", "defined_type": 3, "defined_type_name": "dataset", "group_id": 12763, "url_private_api": "https://api.figshare.com/v2/account/articles/20014042", "url_public_api": "https://api.figshare.com/v2/articles/20014042", "url_private_html": "https://figshare.com/account/articles/20014042", "url_public_html": "https://scielo.figshare.com/articles/dataset/ANALGESIC_EFFICACY_OF_EPIDURAL_MORPHINE_AND_CLONIDINEIN_PATIENTS_UNDERGOING_DECOMPRESSION_OF_THE_LUMBAR_CANAL_A_PROSPECTIVE_RANDOMIZED_TRIAL/20014042", "timeline": {"posted"