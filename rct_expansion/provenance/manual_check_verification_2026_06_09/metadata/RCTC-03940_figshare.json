84d3982a3d21c93ac176", "computed_md5": "8aa15f99b1e184d3982a3d21c93ac176", "mimetype": "application/vnd.ms-excel"}], "folder_structure": {}, "authors": [{"id": 5312486, "full_name": "Nat\u00e1lia Mariano Barboza", "first_name": "Nat\u00e1lia Mariano", "last_name": "Barboza", "is_active": false, "url_name": "_", "orcid_id": ""}, {"id": 12767295, "full_name": "Eduardo Nascimento Floriano", "first_name": "Eduardo Nascimento", "last_name": "Floriano", "is_active": false, "url_name": "_", "orcid_id": ""}, {"id": 12817826, "full_name": "Bruna Lu\u00edsa Motter", "first_name": "Bruna Lu\u00edsa", "last_name": "Motter", "is_active": false, "url_name": "_", "orcid_id": ""}, {"id": 12817829, "full_name": "Fl\u00e1via Cristina da Silva", "first_name": "Fl\u00e1via Cristina da", "last_name": "Silva", "is_active": false, "url_name": "_", "orcid_id": ""}, {"id": 4702198, "full_name": "Suhaila Mahmoud Smaili Santos", "first_name": "Suhaila Mahmoud Smaili", "last_name": "Santos", "is_active": false, "url_name": "_", "orcid_id": ""}], "custom_fields": [{"name": "Read full text", "value": ["http://www.scielo.br/scielo.php?script=sci_arttext&pid=S1809-98232014000100087&lng=en&tlng=en"], "settings": {"placeholder": "Read full text", "is_multiple": false}, "field_type": "url", "order": null, "is_mandatory": false}], "figshare_url": "https://scielo.figshare.com/articles/dataset/Effectiveness_of_physical_therapy_in_association_with_dance_in_healthy_elderly_a_randomized_clinical_trial/20016353", "download_disabled": false, "description": "<p></p><p> Objective:  Verify the physical therapy associated with dance effectiveness in terms of balance, flexibility and agility in healthy seniors.    Methods:  Randomized controlled trial whose sample was divided into two groups: control (GC; 7W/4M; age= 74.1\u00b17.3; n=11) and intervention (GI; 9W/2M; age= 75.7\u00b17.8; n=11). Participants underwent the following types of evaluation in pre and post intervention phases: balance assessment by Berg balance scale, agility according to the Timed Up and Go test and flexibility according to the Wells Bank. A program consisting of 16 therapies with 60 minutes long twice a week followed a protocol of evolution based on the complexity of the exercises and with the aim of stimulating balance, functional independence and muscle stretching. The statistical analysis was performed using software SPSS 15.0 and were used the Mann-Whitney test to compare the groups and Wilcoxon tests to compare pre and post intervention, with significance level of 5%.    Results:  The intervention group showed improved balance (p=0.04), flexibility (p=0.01) and agility (p=0.03) when compared to the control group. The control group showed improvement in the flexibility levels (p=0.01).    Conclusion:  The proposed program was effective in terms of improving balance, flexibility and agility among participants. It is expected that this study can contribute to future research and clinical practice about the association of physical therapy and dance, as a preventive and rehabilitative treatment options.</p><p></p>", "funding": null, "funding_list": [], "version": 1, "status": "public", "size": 665828, "created_date": "2022-06-07T14:04:20Z", "modified_date": "2023-06-06T23:21:19Z", "is_public": true, "is_confidential": false, "is_metadata_record": false, "confidential_reason": "", "metadata_reason": "", "license": {"value": 1, "name": "CC BY 4.0", "url": "https://creativecommons.org/licenses/by/4.0/"}, "tags": ["Aging", "Physical Therapy Specialty", "Dance Therapy"], "keywords": ["Aging", "Physical Therapy Specialty", "Dance Therapy"], "categories": [{"id": 308, "title": "Geriatrics and Gerontology", "parent_id": 142, "path": "", "source_id": "", "taxonomy_id": 10}], "references": ["https://doi.org/10.1590/S1809-98232014000100010"], "has_linked_file": false, "citation": "Barboza, Nat\u00e1lia Mariano; Floriano, Eduardo Nascimento; Motter, Bruna Lu\u00edsa; Silva, Fl\u00e1via Cristina da; Santos, Suhaila Mahmoud Smaili (2014). Effectiveness of physical therapy in association with dance in healthy elderly: a randomized clinical trial. SciELO journals. Dataset. https://doi.org/10.6084/m9.figshare.20016353.v1", "related_materials": [{"id": 53324417, "identifier": "10.1590/S1809-98232014000100010", "title": "Effectiveness of physical therapy in association with dance in healthy elderly: a randomized clinical trial", "relation": "IsSupplementTo", "identifier_type": "DOI", "is_linkout": true, "link": "https://doi.org/10.1590/S1809-98232014000100010"}], "is_embargoed": false, "embargo_date": null, "embargo_type": null, "embargo_title": "", "embargo_reason": "", "embargo_options": [], "id": 20016353, "title": "Effectiveness of physical therapy in association with dance in healthy elderly: a randomized clinical trial", "doi": "10.6084/m9.figshare.20016353.v1", "handle": "", "url": "https://api.figshare.com/v2/articles/20016353", "published_date": "2022-06-07T14:04:20Z", "thumb": "https://s3-eu-west-1.amazonaws.com/ppreviews-scielo-87127105408/35688209/thumb.png", "defined_type": 3, "defined_type_name": "dataset", "group_id": 13090, "url_private_api": "https://api.figshare.com/v2/account/articles/20016353", "url_public_api": "https://api.figshare.com/v2/articles/20016353", "url_private_html": "https://figshare.com/account/articles/20016353", "url_public_html": "https://scielo.figshare.com/articles/dataset/Effectiveness_of_physical_therapy_in_association_with_dance_in_healthy_elderly_a_randomized_clinical_trial/20016353", "timeline": {"posted": "2022-06-07T14:04:20", "publisherPublication": "2014-03-01T14:04:07", "firstOnline": "2022-06-07"}, "resource_title": "Effectiveness of physical therapy in association with dance in healthy elderly: a randomized clinical trial", "resource_doi": "10.1590/S1809-98232014000100010"}