{"created": "2025-11-09T04:21:43.396559+00:00", "modified": "2025-11-09T04:21:43.561436+00:00", "id": 17562062, "conceptrecid": "17562061", "doi": "10.5281/zenodo.17562062", "conceptdoi": "10.5281/zenodo.17562061", "doi_url": "https://doi.org/10.5281/zenodo.17562062", "metadata": {"title": "Effects of a Lamellar-Structured Ceramide-Containing Emulsion on the Skin Barrier Function of Surgical Nurses: A Randomized Controlled Trial", "doi": "10.5281/zenodo.17562062", "publication_date": "2025-11-09", "description": "<p>This dataset contains anonymised participant-level data from a single-centre, open-label, parallel-group randomised controlled trial that evaluated the effects of a lamellar-structured ceramide-containing emulsion on the hand skin barrier function of surgical nurses.</p>\n<p>The trial was conducted in the operating department of a Japanese medical centre. Thirty-five surgical nurses were randomly allocated to an intervention group (emulsion applied twice daily for seven days) or a control group (no additional skin care). Skin barrier function was assessed at baseline and on days 1, 3, and 7 under standardised environmental conditions.</p>\n<p>The dataset includes:</p>\n<ul>\n<li>\n<p>Group allocation (intervention vs control)</p>\n</li>\n<li>\n<p>Participant characteristics (age, years of operating room experience, hand hygiene practices)</p>\n</li>\n<li>\n<p>Skin physiology measures at each timepoint:</p>\n<ul>\n<li>\n<p>Transepidermal water loss (TEWL)</p>\n</li>\n<li>\n<p>Stratum corneum moisture (corneometry)</p>\n</li>\n<li>\n<p>Skin surface pH</p>\n</li>\n<li>\n<p>Skin temperature and ambient humidity</p>\n</li>\n</ul>\n</li>\n<li>\n<p>Clinical dry skin scores assessed from dermoscopic images by a blinded plastic surgeon</p>\n</li>\n</ul>", "access_right": "open", "creators": [{"name": "Hara, Kentaro", "affiliation": "Nagasaki University Graduate School of Biomedical", "orcid": "0000-0002-2677-3816"}], "contributors": [{"name": "Hara, Kentaro", "affiliation": null, "type": "ContactPerson", "orcid": "0000-0002-2677-3816"}], "language": "alu", "resource_type": {"title": "Dataset", "type": "dataset"}, "license": {"id": "cc-by-4.0"}, "relations": {"version": [{"index": 0, "is_last": true, "parent": {"pid_type": "recid", "pid_value": "17562061"}}]}}, "title": "Effects of a Lamellar-Structured Ceramide-Containing Emulsion on the Skin Barrier Function of Surgical Nurses: A Randomized Controlled Trial", "links": {"self": "https://zenodo.org/api/records/17562062", "self_html": "https://zenodo.org/records/17562062", "preview_html": "https://zenodo.org/records/17562062?preview=1", "doi": "https://doi.org/10.5281/zenodo.17562062", "self_doi": "https://doi.org/10.5281/zenodo.17562062", "self_doi_html": "https://zenodo.org/doi/10.5281/zenodo.17562062", "reserve_doi": "https://zenodo.org/api/records/17562062/draft/pids/doi", "parent": "https://zenodo.org/api/records/17562061", "parent_html": "https://zenodo.org/records/17562061", "parent_doi": "https://doi.org/10.5281/zenodo.17562061", "parent_doi_html": "https://zenodo.org/doi/10.5281/zenodo.17562061", "self_iiif_manifest": "https://zenodo.org/api/iiif/record:17562062/manifest", "self_iiif_sequence": "https://zenodo.org/api/iiif/record:17562062/sequence/default", "files": "https://zenodo.org/api/records/17562062/files", "media_files": "https://zenodo.org/api/records/17562062/media-files", "archive": "https://zenodo.org/api/records/17562062/files-archive", "archive_media": "https://zenodo.org/api/records/17562062/media-files-archive", "latest": "https://zenodo.org/api/records/17562062/versions/latest", "latest_html": "https://zenodo.org/records/17562062/latest", "versions": "https://zenodo.org/api/records/17562062/versions", "draft": "https://zenodo.org/api/records/17562062/draft", "access_links": "https://zenodo.org/api/records/17562062/access/links", "access_grants": "https://zenodo.org/api/records/17562062/access/grants", "access_users": "https://zenodo.org/api/records/1