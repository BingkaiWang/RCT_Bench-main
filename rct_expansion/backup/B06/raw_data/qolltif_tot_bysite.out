  Missing are * ;

  USEVARIABLES ARE group site
  QOLF1-QOLF7;
  CLUSTER = SITE;

  DEFINE:
  !replace TOT1-TOT7 to run analyses for other QOLLTI-F domains
  QOLF1=TOT1;
  QOLF2=TOT2;
  QOLF3=TOT3;
  QOLF4=TOT4;
  QOLF5=TOT5;
  QOLF6=TOT6;
  QOLF7=TOT7;

  Analysis:
     Type = COMPLEX;
     STARTS = 100;
     estimator = mlr;

  MODEL:
   I BY QOLF1@1 QOLF2@1 QOLF3@1  QOLF4@1 QOLF5@1 QOLF6@1 QOLF7@1;
   S BY QOLF1@0 QOLF2 QOLF3  QOLF4 QOLF5 QOLF6 QOLF7@1 (s1-s7);
   I with S;
   i@0;
   i on group@0;
   s on group;
   [QOLF1-QOLF7@0];
   [i s] (i s);

  MODEL CONSTRAINT:
  NEW (T1-T7);
  T1=i;
  T2=i+(s*s2);
  T3=i+(s*s3);
  T4=i+(s*s4);
  T5=i+(s*s5);
  T6=i+(s*s6);
  T7=i+(s);

  OUTPUT:
  SAMPSTAT STANDARDIZED CINTERVAL TECH1 RESIDUAL tech9;

  PLOT:
  Type is plot1 plot2 plot3;
    Series is
    QOLF1-QOLF7(*)
    ;




